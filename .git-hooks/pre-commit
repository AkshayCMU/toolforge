#!/usr/bin/env bash
# pre-commit: block commits that contain secrets or API keys.
# Install once with: bash scripts/install-hooks.sh
#
# To bypass a specific line in a test fixture, append  # nocheck  to that line.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

VIOLATIONS=0

# Patterns that indicate a secret (case-insensitive on key names, exact on values)
declare -a PATTERNS=(
    'ANTHROPIC_API_KEY\s*=\s*["\x27]?sk-'
    'sk-ant-api[0-9A-Za-z_-]+'
    'OPENAI_API_KEY\s*=\s*["\x27]?sk-'
    'sk-proj-[0-9A-Za-z_-]+'
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'
    'password\s*=\s*["\x27][^"\x27]{6,}'
    'secret\s*=\s*["\x27][^"\x27]{6,}'
    'api_key\s*=\s*["\x27][^"\x27]{6,}'
    'token\s*=\s*["\x27][^"\x27]{10,}'
)

# Check if .env itself is staged (never allow)
if git diff --cached --name-only | grep -qE '^\.env$'; then
    echo -e "${RED}[pre-commit] BLOCKED: .env file is staged. Remove it with:${NC}"
    echo "  git reset HEAD .env"
    VIOLATIONS=$((VIOLATIONS + 1))
fi

# Scan staged file content
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
    while IFS= read -r file; do
        # Skip binary files
        if git show ":$file" | file - | grep -q 'binary'; then
            continue
        fi

        for pattern in "${PATTERNS[@]}"; do
            # Get matching lines, excluding those with # nocheck
            matches=$(git show ":$file" 2>/dev/null \
                | grep -nEi -e "$pattern" \
                | grep -v '# nocheck' \
                || true)

            if [ -n "$matches" ]; then
                echo -e "${RED}[pre-commit] SECRET DETECTED in $file:${NC}"
                echo "$matches" | head -5 | sed 's/^/  /'
                echo -e "${YELLOW}  Add '# nocheck' to the line if this is intentional (e.g. test fixture).${NC}"
                VIOLATIONS=$((VIOLATIONS + 1))
            fi
        done
    done <<< "$STAGED_FILES"
fi

if [ "$VIOLATIONS" -gt 0 ]; then
    echo ""
    echo -e "${RED}[pre-commit] Commit blocked: $VIOLATIONS secret pattern(s) found.${NC}"
    echo "Fix the violations above, then retry."
    exit 1
fi

exit 0
